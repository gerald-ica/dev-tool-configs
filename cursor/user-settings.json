{
    "window.commandCenter": true,
    "workbench.colorTheme": "Solarized Dark",
    "cursor.cpp.enablePartialAccepts": true,
    "cursor.agent_layout_browser_beta_setting": true,
    "cursor.enable_git_worktrees_setting": true,
    "cursor.rpcFileLogger.enabled": true,
    "editor.largeFileOptimizations": false,
    "terminal.integrated.inheritEnv": true,
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.profiles.osx": {
        "zsh": {
            "path": "/bin/zsh",
            "args": [
                "-l"
            ]
        }
    },
    "python.languageServer": "None",
    "cursorpyright.disableLanguageServices": true,
    "Lingma.localMachineModel": true,
    "Lingma.aI Chat.commandAllowlistInAgentMode": "chmod,cd,python3,echo,head,wc,cat,kill,sleep,ls,pip,npm,curl,which,python,sh,export,grep,sed,cp,op",
    "Lingma.aI Chat.mcpToolsInAgentMode": true,
    "Lingma.aI Chat.webToolsInAsk/AgentMode": "Auto-execute",
    "superdesign.aiModel": "claude-4-opus-20250514",
    "superdesign.aiModelProvider": "openrouter",
    "superdesign.openrouterApiKey": "YOUR_OPENROUTER_API_KEY",
    "superdesign.openaiApiKey": "YOUR_OPENAI_API_KEY",
    "superdesign.anthropicApiKey": "YOUR_ANTHROPIC_API_KEY",
    "amp.url": "https://ampcode.com/",
    "editor.wordBasedSuggestions": "off",
    "amp.tab.enabled": true,
    "amp.experimental.modes": [
        "deep"
    ],
    "amp.mcpServers": {
        "playwright": {
            "command": "npx",
            "args": [
                "-y",
                "@playwright/mcp@latest",
                "--headless",
                "--isolated"
            ]
        }
    },
    "amp.dangerouslyAllowAll": true,
    "cody.suggestions.mode": "off",
    "files.autoSave": "afterDelay",
    "editor.multiCursorModifier": "ctrlCmd",
    "git.autofetch": true,
    "cursor.composer.shouldChimeAfterChatFinishes": true,
    "geminicodeassist.project": "eastern-banner-3sf6z",
    "cloudcode.compute.sshInternalIp": true,
    "remote.SSH.remotePlatform": {
        "gerald@192.168.1.73": "windows"
    },
    "security.promptForLocalFileProtocolHandling": false,
    "chromiumide.metrics.showMessage": false,
    "chromiumide.metrics.collectMetrics": true,
    "cursor.composer.usageSummaryDisplay": "always",
    "lldb.library": "/Applications/Xcode.app/Contents/SharedFrameworks/LLDB.framework/Versions/A/LLDB",
    "lldb.launch.expressions": "native",
    "firebase.dataConnect.alwaysAllowMutationsInProduction": true,
    "firebase.dataConnect.skipToAppFolderSelect": true,
    "firebase.emulators.exportOnExit": true,
    "git.enableSmartCommit": true
}
